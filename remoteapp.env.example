RDP_HOST=10.15.1.130
RDP_PASSWORD=sua_senha_do_windows_remoto
SENIOR_SHORTCUT_PATH="C:\Users\Public\Desktop\Senior Produção\Sapiens\Gestão Empresarial (ERP).lnk"
SENIOR_USER=seu_usuario_do_senior
