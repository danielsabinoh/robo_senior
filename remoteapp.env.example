RDP_PASSWORD_PROMPT_TIMEOUT=5
MSTSC_READY_DELAY=3
RUN_DIALOG_DELAY=1
RDP_CONFIRM_CERTIFICATE=true
RDP_USE_CLIPBOARD=false
RDP_REDIRECT_DRIVES=true
